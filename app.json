{
  "expo": {
    "name": "SaúdeJá",
    "slug": "saudeja",
    "version": "1.0.0",
    "scheme": "saudeja",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#006B3C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.saudeja.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Para encontrar farmácias e UBS próximas a você",
        "NSCameraUsageDescription": "Para escanear o código de barras do medicamento"
      }
    },
    "android": {
      "package": "com.saudeja.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#006B3C"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#006B3C"
        }
      ],
      [
        "expo-barcode-scanner",
        {
          "cameraPermission": "Para identificar medicamentos pelo código de barras"
        }
      ],
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Para encontrar farmácias e estabelecimentos de saúde próximos a você"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
